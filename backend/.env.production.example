# Шаблон прод-настроек для сервера.
# На VPS скопировать в backend/.env и подставить РЕАЛЬНЫЕ значения (этот файл — только образец).

# Подключение к PostgreSQL. Пароль — тот, что задавали при CREATE USER polymer.
# Используй в пароле только буквы и цифры, чтобы не ломать строку подключения.
DATABASE_URL="postgresql://polymer:ПАРОЛЬ_БД@localhost:5432/polymerplast?schema=public"

PORT=4000

# Длинная случайная строка (можно сгенерировать: openssl rand -hex 32)
JWT_SECRET="ЗАМЕНИ_НА_ДЛИННУЮ_СЛУЧАЙНУЮ_СТРОКУ"
JWT_EXPIRES_IN="7d"

# Публичный адрес API (для ссылок на PDF/фото). Через него ходит фронтенд.
PUBLIC_BASE_URL="https://api.b2b-polimer-plast.ru"

ORDER_AUTOCANCEL_HOURS=72

# Чат-бот: по умолчанию правиловый. Режим «ИИ» включается в интерфейсе и работает,
# когда дома поднят обратный SSH-туннель к Ollama (см. LLM-ТУННЕЛЬ-ВКЛ.bat).
# Если ПК выключен — бот автоматически отвечает правилами.
LLM_PROVIDER=rules
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
