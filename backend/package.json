{
  "name": "polymer-plast-backend",
  "version": "1.0.0",
  "description": "Backend B2B-приложения ООО ТПК «Полимер-Пласт» (Node.js + Express + PostgreSQL)",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:import": "node prisma/import.js",
    "db:retag": "node prisma/retag.js",
    "db:seed": "node prisma/seed.js",
    "db:catalog": "node prisma/generateCatalog.js",
    "db:setup": "node prisma/import.js && node prisma/seed.js && node prisma/generateCatalog.js",
    "db:reset": "prisma migrate reset --force",
    "smoke": "node scripts/smoke.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "pdfkit": "^0.16.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "csv-parse": "^5.6.0",
    "prisma": "^6.2.1"
  }
}
