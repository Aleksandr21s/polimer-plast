# Скопируйте этот файл в .env и при необходимости измените значения.

# Подключение к PostgreSQL (пользователь:пароль@host:порт/база)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/polymerplast?schema=public"

# Порт API-сервера
PORT=4000

# Секрет для подписи JWT (в продакшене заменить на случайную строку)
JWT_SECRET="dev-secret-change-me-polymer-plast-2026"
JWT_EXPIRES_IN="7d"

# Базовый URL для ссылок на файлы/документы (используется мобильным приложением)
PUBLIC_BASE_URL="http://localhost:4000"

# Сколько часов даётся клиенту на оплату/подтверждение до авто-отмены
ORDER_AUTOCANCEL_HOURS=72

# Движок чат-бота по умолчанию: rules (правиловый, без LLM) | ollama (локальная LLM).
# Используется, когда клиент не передал движок явно (например, в smoke-тесте).
# Рекомендуется rules — режим «ИИ» включается переключателем в чате (параметр engine).
LLM_PROVIDER=rules
# Адрес локального сервера Ollama (управляется OLLAMA-ВКЛ.bat / OLLAMA-ВЫКЛ.bat)
OLLAMA_URL=http://localhost:11434
# Модель Ollama для режима «ИИ» (см. OLLAMA-ВКЛ.bat). Запасная — qwen2.5:7b
OLLAMA_MODEL=qwen2.5:14b
