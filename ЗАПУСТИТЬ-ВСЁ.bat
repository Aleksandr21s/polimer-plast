@echo off
chcp 65001 >nul
title Полимер-Пласт — Запуск всего проекта

echo ============================================================
echo   ПОЛИМЕР-ПЛАСТ — запуск API и приложения
echo ============================================================
echo.
echo Открываю два окна:
echo   1) Бэкенд (API)     — http://localhost:4000
echo   2) Приложение (Expo)
echo.

start "Полимер-Пласт — API" "%~dp0start-backend.bat"

echo Жду 5 секунд, пока поднимется API...
timeout /t 5 /nobreak >nul

start "Полимер-Пласт — Приложение" "%~dp0start-app.bat"

echo.
echo ------------------------------------------------------------
echo  ГОТОВО. Когда оба окна загрузятся:
echo    - в окне «Приложение» нажмите  w  — откроется веб-версия
echo      (или http://localhost:8081 в браузере)
echo    - для телефона: сканируйте QR в Expo Go
echo.
echo  Демо-входы:
echo    Клиент:   client@demo.ru / client123
echo    Менеджер: manager@polymer-plast.ru / manager123
echo ------------------------------------------------------------
echo.
echo Это окно можно закрыть. Закрытие тех двух окон остановит сервера.
timeout /t 12 /nobreak >nul
